# WooCommerce MCP Server Configuration
# Rename this file to .env and fill in your credentials

# 1. Store URL (Required)
WOOCOMMERCE_URL=https://your-store.com

# 2. WooCommerce REST API Keys (Required)
# Generate these in WooCommerce > Settings > Advanced > REST API
WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. WordPress Credentials (Optional - only for managing posts/content)
# It's recommended to use Application Passwords
WORDPRESS_USERNAME=your_username
WORDPRESS_PASSWORD=your_application_password

# 4. Logging Level (Optional)
# Options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
